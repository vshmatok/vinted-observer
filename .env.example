# ============================================
# Telegram Bot Configuration
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ============================================
# Vinted Configuration
# ============================================
# Vinted domain: PL, FR, DE, UK, ES, IT, NL, BE, LT, LU, CZ, AT
VINTED_DOMAIN=PL

# ============================================
# Proxy Configuration
# ============================================
# Path to proxy configuration file (JSON)
# See README.md for proxy configuration structure
PROXY_CONFIG_PATH=src/resources/proxies.json

# ============================================
# User Agents Configuration
# ============================================
# Path to user agents file (JSON)
USER_AGENTS_PATH=src/resources/agents.json

# ============================================
# Database Configuration
# ============================================
DATABASE_PATH=database.db
DB_CLEANUP_INTERVAL_HOURS=24
DB_LISTING_RETENTION_DAYS=1
# SQLite busy timeout in milliseconds (how long to wait for locks before failing)
# 5000ms (5 seconds) is recommended for concurrent operations with WAL mode
DB_BUSY_TIMEOUT=5000

# ============================================
# Logging Configuration
# ============================================
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# When changing the format, change log parser in errors monitoring accordingly. Do not remove %(levelname)s as it's used to identify error lines for /status command.
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_DATE_FORMAT=%Y-%m-%d %H:%M:%S
# Optional: Path to log file (leave empty to disable file logging)
LOG_FILE=logs/app.log

# ============================================
# Status Command Configuration
# ============================================
# Timeframe in hours for displaying found items in /status command
STATUS_ITEMS_TIMEFRAME_HOURS=1
# Number of recent errors to fetch for /status command
ERROR_FETCH_AMOUNT=10
# Log levels to treat as errors (comma-separated, no spaces)
ERROR_LOG_LEVELS=ERROR,CRITICAL

# ============================================
# Search Configuration
# ============================================
# Delay in seconds between search iterations per search task.
#
# Tuning guide:
#   - Each search task polls Vinted API in a loop with this delay between requests.
#   - Optimal setup: 1 proxy per search, 1 second delay — gives near-instant results.
#   - More searches than proxies = requests queue up, effective delay grows.
#   - Formula: effective_interval ≈ SEARCH_SLEEP_TIME × (searches / proxies)
#
# Examples:
#   1 proxy,  1 search  → 1s delay is fine (1 req/s)
#   1 proxy,  5 searches → consider 5 proxies or accept ~5s effective interval
#   3 proxies, 10 searches → ~3.3s effective interval per search
#
# If you get rate-limited or IP-banned, add more proxies rather than increasing delay.
# This bot is designed for near-instant notifications — increasing delay defeats the purpose.
SEARCH_SLEEP_TIME=1

# ============================================
# Docker Overrides
# ============================================
# Uncomment these when running with Docker:
# DATABASE_PATH=/app/data/database.db
# LOG_FILE=/app/logs/app.log
